# CCTV RTSP Stream Configuration
# For production/real camera, use the RTSP URL of your Dahua stream.
# Example: rtsp://username:password@192.168.1.108:554/cam/realmonitor?channel=1&subtype=0
# For testing without a physical camera, use "mock"
RTSP_URL=mock
RTSP_HOST=127.0.0.1
RTSP_USERNAME=admin
RTSP_PASSWORD=sheild222@
RTSP_PORT=19979

# Reconnection interval in seconds
RECONNECT_INTERVAL=5

# Target frames per second
TARGET_FPS=25

# Directory names (will be created automatically)
CAPTURE_DIR=captures
LOG_DIR=logs
