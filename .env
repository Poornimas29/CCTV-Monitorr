# CCTV RTSP Stream Configuration
# Set to 'mock' to use the built-in test feed.
# CameraManager builds the live URL from RTSP_HOST, RTSP_PORT, RTSP_USERNAME and RTSP_PASSWORD below.
RTSP_URL=mock
RTSP_HOST=127.0.0.1
RTSP_USERNAME=admin
RTSP_PASSWORD=sheild222@
RTSP_PORT=22494

# Reconnection interval in seconds
RECONNECT_INTERVAL=5

# Target frames per second
TARGET_FPS=25

# Directory names
CAPTURE_DIR=captures
LOG_DIR=logs
