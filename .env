# CCTV RTSP Stream Configuration
# Set to 'mock' to use the built-in test feed.
# CameraManager builds the live URL from RTSP_HOST, RTSP_PORT, RTSP_USERNAME and RTSP_PASSWORD below.
RTSP_URL=
RTSP_HOST=127.0.0.1
RTSP_USERNAME=admin
RTSP_PASSWORD=sheild222@
RTSP_PORT=25356
# Reconnection interval in seconds
RECONNECT_INTERVAL=5

# ----- Playback override (temporary video) -----
ENABLE_PLAYBACK=1
# Set to 1 to use a pre‑recorded video instead of live RTSP.
# Provide either a local file path or an alternative RTSP URL.
PLAYBACK_URL="C:\Users\poornima.s\Downloads\SmartPss\Vel New_ch3_20260717160001_20260717163058.mp4"
# ------------------------------------------------
# Target frames per second
TARGET_FPS=25

# ─── Detection Confidence Thresholds ──────────────────────────────────────────
# Lower values = more sensitive (catches partial/occluded persons seen from above)
# Higher values = stricter (fewer false positives)
# CCTV overhead cameras need lower thresholds (~0.35) because persons are often
# partially visible, bending, or sitting and appear short/wide.
CONF_PERSON=0.35
CONF_PHONE=0.25

# Directory names
CAPTURE_DIR=captures
LOG_DIR=logs

# ─── Tracking & Identity Pipeline ────────────────────────────────────────────

# How long (seconds) a lost track is held before the session is finalized as "exited".
# Must be long enough to survive temporary occlusions, bending, walking behind racks, etc.
# 60 seconds = 1 full minute of absence before we close the session.
TRACK_TIMEOUT=60.0

# How often (seconds) face recognition is attempted on an unidentified track.
# 0.5s provides fast lock-on for top-down overhead cameras where faces are
# visible only briefly. Combine with the 2-worker async pool for best results.
RECOGNITION_INTERVAL=0.5

# Minimum cosine similarity score to accept a face match.
# 0.50 reduces false-positive identity assignments vs the old 0.40.
RECOGNITION_THRESHOLD=0.50

# Minimum face size (pixels) for recognition to be attempted.
# 30px is the floor for low-resolution/distant CCTV feeds.
MIN_FACE_SIZE=30

# Laplacian blur variance floor — reject images more blurred than this.
MIN_FACE_QUALITY=3.0

# Number of consecutive matching frames required to lock a Track ID to an employee.
# 2 = locks in 2 seconds at 1.0s interval. Reduces recognition delay significantly.
MIN_CONSECUTIVE_MATCHES=2

# Cosine similarity threshold for Body Re-ID track RECOVERY.
# Used ONLY to re-link a person to their session when their Track ID changes.
# Must be high (0.75) to prevent false re-linking.
REID_SIMILARITY_THRESHOLD=0.75

# General similarity threshold (used as fallback / shared config).
SIMILARITY_THRESHOLD=0.50

# Phone usage confirmation window (seconds).
PHONE_USAGE_CONFIRM_SECONDS=2.0

# Unknown track log retention (minutes). Logs older than this are auto-deleted.
UNKNOWN_TRACK_CLEANUP_MINUTES=15

# NOTE: MAX_RECOGNITION_ATTEMPTS has been removed.
# Recognition retries indefinitely until identity is locked. There is no reason
# to permanently abandon a visible, live person after N failed attempts.
